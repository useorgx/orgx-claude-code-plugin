{
  "name": "@useorgx/claude-code-plugin",
  "version": "0.1.5",
  "description": "OrgX Claude Code plugin with MCP, operator chronicle reporting, runtime telemetry hooks, Work Graph reconciliation, and Sovereign Execution peer sidecar",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useorgx/orgx-claude-code-plugin.git"
  },
  "bin": {
    "orgx-claude-code-peer": "lib/peer/cli.mjs",
    "orgx-claude-code-reconcile-hooks": "hooks/scripts/orgx-work-graph-reconcile.mjs"
  },
  "files": [
    ".claude-plugin/",
    ".github/",
    "agents/",
    "commands/",
    "docs/",
    "hooks/",
    "lib/",
    "scripts/",
    "skills/",
    "plugin.manifest.json",
    "README.md",
    "tsconfig.json"
  ],
  "exports": {
    ".": "./lib/peer/peer.mjs",
    "./peer": "./lib/peer/peer.mjs"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs lib/peer/peer.test.mjs",
    "test:peer": "node --test lib/peer/peer.test.mjs",
    "verify": "node scripts/verify-plugin.mjs",
    "check": "npm run typecheck && npm run test && npm run verify",
    "prepublishOnly": "npm run check",
    "pack": "mkdir -p artifacts && npm pack --pack-destination artifacts",
    "release:dry-run": "node scripts/release-dry-run.mjs",
    "dev:claude": "claude --plugin-dir .",
    "peer:start": "node lib/peer/cli.mjs"
  },
  "dependencies": {
    "@sentry/node": "10.65.0",
    "@useorgx/orgx-gateway-sdk": "github:useorgx/orgx-gateway-sdk#c2eb30d4f2df6b19edd3894ad06adb8b3e1ddbdb",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
