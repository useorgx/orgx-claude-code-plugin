{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["hooks/scripts/**/*.mjs", "scripts/**/*.mjs", "tests/**/*.mjs"]
}
